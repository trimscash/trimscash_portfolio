---
import "../styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/Avator.png" />
    <meta name="viewport" content="width=device-width" />
    <title>404 - trimscash</title>
    <meta name="description" content="ページが見つかりません" />
  </head>
  <body
    class="bg-[radial-gradient(circle_at_20%_10%,#161616_0%,#070707_45%)] text-[#f2f2f2]"
  >
    <main
      class="mx-auto flex min-h-screen w-[min(1100px,92vw)] flex-col items-center justify-center gap-6 text-center"
    >
      <h1 class="m-0 text-[clamp(60px,10vw,120px)] text-[#2a2a2a]">404</h1>
      <p class="m-0 text-[#a7a7a7]">ページが見つかりませんでした</p>
      <a
        class="no-underline text-[var(--accent)] hover:underline"
        href="/"
      >← ホームに戻る</a>
    </main>
  </body>
</html>